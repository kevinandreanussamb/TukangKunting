{
  "manifest_version": 3,
  "name": "Tukang Kunting (Commercial)",
  "version": "2.0",
  "description": "Nyuruh Tukang Aja!!",
  "icons": { "48": "icon.png" },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icon.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "icon.png",
    "default_title": "Suruh Tukang!"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
