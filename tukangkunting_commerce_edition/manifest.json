{
  "manifest_version": 3,
  "name": "TukangKunting Commerce Edition",
  "version": "1.5.932.580",
  "description": "Tukang ajah",
  "icons": {
    "48": "icon.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "notifications"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+T",
        "mac": "Command+Shift+T"
      },
      "description": "Buka Tukangkunting"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icon.png",
        "shared/*.js",
        "modules/*.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_icon": "icon.png",
    "default_title": "Suruh Tukang"
  },
  "version_name": "1.5.5"
}
